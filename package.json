{
  "name": "lazy-dotfiles",
  "private": true,
  "type": "module",
  "module": "src/index.tsx",
  "scripts": {
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "dev": "bun run generate-routes && bun run --watch src/index.tsx",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@opentui/core": "^0.1.61",
    "@opentui/react": "^0.1.61",
    "@tanstack/react-router": "^1.141.6",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@tanstack/router-cli": "^1.141.7",
    "@types/bun": "latest",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
